# =========================================================================
# NutriNest - Production-Ready Git Ignore Configuration
# =========================================================================

# -------------------------------------------------------------------------
# v0 / Sandbox / Platform-Specific Files
# -------------------------------------------------------------------------
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
.vercel/

# -------------------------------------------------------------------------
# Dependency Directories (Node.js & Build Tools)
# -------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/

# -------------------------------------------------------------------------
# Build Outputs & Cache
# -------------------------------------------------------------------------
.next/
out/
build/
dist/
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tsbuildinfo

# -------------------------------------------------------------------------
# Local Environment Variables & Secrets
# -------------------------------------------------------------------------
# Ignore all environment files containing local secrets and databases
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.local
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local

# DO NOT ignore example files as they are templates/guides for other developers
!.env.example
!backend/.env.example

# -------------------------------------------------------------------------
# Logs and Diagnostics
# -------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------------------------------------
# IDE / Editor Configurations
# -------------------------------------------------------------------------
.vscode/
# Keep essential shared VS Code configurations if they exist
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -------------------------------------------------------------------------
# Operating System Files
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -------------------------------------------------------------------------
# Testing and Coverage
# -------------------------------------------------------------------------
coverage/
.nyc_output/
htmlcov/